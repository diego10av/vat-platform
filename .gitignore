# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# uploads and data
/uploads/
/data/

# Real client documents must never be committed. The extractor
# diagnostic (scripts/extractor-diagnostic.ts) is fed real PDFs
# from external paths (e.g. ~/Desktop/xxx.pdf) — if one ever
# ends up next to the repo root by accident, this catches it.
# Synthetic fixtures go under src/__tests__/fixtures/ and are
# whitelisted by their path.
/*.pdf
/*.PDF
/*.jpg
/*.JPG
/*.jpeg
/*.JPEG
/*.png
/*.PNG
scripts/extractor-diagnostic/output/

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/playwright-report/
/test-results/
/playwright/.cache/
